---
import Base from '../layouts/Base.astro';
import Cta from '../components/Cta.astro';
import { u, STRAZI_PRINCIPALE, SITE } from '../data/site';
import { LOCATII } from '../data/locatii';
import { ARTICOLE_1 } from '../data/articole-1';
import { ARTICOLE_2 } from '../data/articole-2';
import { ARTICOLE_3 } from '../data/articole-3';
export function getStaticPaths() {
  const ARTICOLE = [...ARTICOLE_1, ...ARTICOLE_2, ...ARTICOLE_3];
  const seen = new Set();
  const loc = LOCATII.map(([slug, nume]) => ({ params: { slug }, props: { nume, html: null, desc: '' } }));
  loc.forEach(x => seen.add(x.params.slug));
  const art = ARTICOLE.filter(a => !seen.has(a.s)).map(a => ({ params: { slug: a.s }, props: { nume: a.t, html: a.h, desc: a.d } }));
  return [...loc, ...art];
}
const { nume, html, desc } = Astro.props;
const slug = Astro.params.slug;
const zona = nume.replace(/^Reparații TV (pe )?/, '').replace(/^Reparatii TV (pe )?/, '');
const title = nume + ' | Reparatii TV Bucuresti';
const description = desc && desc.length > 10 ? desc : ('Service televizoare la domiciliu — ' + nume + '. Diagnosticare și deplasare gratuită, garanție 6–12 luni.');
const servicii = [
  'TV nu pornește — sursă, placă principală, rescriere eMMC cu programator special',
  'Backlight LED și panou LED / OLED / QLED',
  'Linii sau pete pe ecran — placă T-CON',
  'Probleme de sunet și software Smart TV',
  'Curățare internă și înlocuire condensatori devalorizați',
];
const norm = (x) => x.toLowerCase().replace(/[ăâ]/g,'a').replace(/î/g,'i').replace(/[șş]/g,'s').replace(/[țţ]/g,'t').replace(/[^a-z0-9]+/g,' ').trim();
const cleanNm = (nm) => nm.replace(/^Reparații TV (pe )?/, '').replace(/^Reparatii TV (pe )?/, '').replace(/\s*[–-]\s*Sector.*$/, '').replace(/\s*\(S\d\)\s*$/i, '').trim();
const m = slug.match(/sector-?(\d)/);
const sectorNr = m ? m[1] : null;
let strazi = [];
if (sectorNr) {
  const fromLoc = LOCATII.filter(([sl, nm]) => (new RegExp('(sector\\D{0,3}' + sectorNr + '\\b)|(\\(s' + sectorNr + '\\))', 'i').test(nm)) && sl !== slug)
    .map(([sl, nm]) => ({ sl, nm: cleanNm(nm) }));
  const curated = (STRAZI_PRINCIPALE[sectorNr] || []).map(name => {
    const k = norm(name);
    const hit = LOCATII.find(([sl, nm]) => { const kk = norm(cleanNm(nm)); return kk === k || kk.includes(k) || k.includes(kk); });
    return { sl: hit ? hit[0] : null, nm: name };
  });
  const seen = new Set();
  [...curated, ...fromLoc].forEach(x => { const k = norm(x.nm); if (k && !seen.has(k)) { seen.add(k); strazi.push(x); } });
  strazi.sort((a, b) => a.nm.localeCompare(b.nm, 'ro'));
}
const canonical = new URL(Astro.url.pathname, SITE.domeniu).href;
const BRAND_SLUGS = new Set(['reparatii-televizoare-sony','reparatii-televizoare-philips','reparatii-tv-panasonic','reparatii-televizoare-horizon']);
const isBrand = BRAND_SLUGS.has(slug);
const isLocatie = html === null;
const crumbs = [{ name: 'Acasă', item: SITE.domeniu + '/' }];
if (sectorNr) crumbs.push({ name: 'Sectoare', item: SITE.domeniu + '/sectoare/' });
crumbs.push({ name: zona, item: canonical });
const graph = [{
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({ '@type': 'ListItem', position: i + 1, name: c.name, item: c.item })),
}];
if (isLocatie || isBrand) {
  graph.unshift({
    '@type': 'Service',
    serviceType: 'Reparații televizoare la domiciliu',
    name: nume,
    url: canonical,
    description,
    areaServed: isBrand
      ? [{ '@type': 'City', name: 'București' }, { '@type': 'AdministrativeArea', name: 'Județul Ilfov' }]
      : { '@type': sectorNr ? 'AdministrativeArea' : 'Place', name: zona },
    provider: { '@id': 'https://www.reparatiitvbucuresti.ro/#business' },
    offers: { '@type': 'Offer', priceCurrency: 'RON', url: SITE.domeniu + '/preturi-reparatii-tv/' },
  });
}
const schemaExtra = { '@context': 'https://schema.org', '@graph': graph };
---
<Base title={title} description={description} schemaExtra={schemaExtra}>
  <section class="hero-img"><div class="wrap">
    <span class="badge">La domiciliu · Garanție 6–12 luni</span>
    <h1>{nume}</h1>
    <p class="lead">Service televizoare profesional în București și Ilfov. Diagnosticare și deplasare gratuită, garanție 6–12 luni.</p>
  </div></section>
  {html ? (
    <section class="sec"><div class="wrap">
      <div class="entry" set:html={html} />
      <Cta titlu="Aveți nevoie de service TV? Sunați-ne!" />
    </div></section>
  ) : (
    <section class="sec"><div class="wrap">
      <img src="https://www.reparatiielectronice.ro/img/tv.jpg" alt={'Reparatii TV ' + zona} style="width:100%;max-height:300px;object-fit:cover;border-radius:14px;margin:0 0 18px;box-shadow:0 2px 14px rgba(20,54,93,.12)" loading="lazy" />
      <p>Oferim service profesional de televizoare în zona <strong>{zona}</strong>, cu deplasare gratuită în București și Ilfov. Reparăm orice marcă — Samsung, LG, Sony, Philips, Panasonic — televizoare LED, OLED și QLED. Plătiți doar dacă televizorul funcționează.</p>
      <h2>Ce reparăm</h2>
      <ul class="checks">{servicii.map(s => <li>{s}</li>)}</ul>
      {sectorNr && strazi.length > 0 && (
        <div>
          <h2>Bulevarde și străzi principale în Sector {sectorNr}</h2>
          <p>Ne deplasăm gratuit pe toate străzile din Sector {sectorNr}, inclusiv:</p>
          <div class="grid g3" style="gap:4px 18px">
            {strazi.map(s => s.sl
              ? <a href={u(s.sl + '/')} style="font-size:14px;padding:3px 0;display:block">{s.nm}</a>
              : <span style="font-size:14px;padding:3px 0;display:block;color:var(--ink)">{s.nm}</span>)}
          </div>
        </div>
      )}
      <p style="margin-top:18px">Vedeți <a href={u('preturi-reparatii-tv/')}>prețurile orientative</a> sau aflați <a href={u('cum-decurge-procesul-de-reparatie/')}>cum decurge procesul</a>.</p>
      <Cta titlu="Aveți un TV defect? Sunați-ne acum!" />
    </div></section>
  )}
</Base>
