---
import Base from '../layouts/Base.astro';
import Cta from '../components/Cta.astro';
const title = 'Reparatii TV Despre noi Bucuresti - Service la domiciliu';
const description = 'Despre echipa Reparatii TV Bucuresti: deplasare gratuită la domiciliu, reparăm orice marcă TV — Samsung, LG, Sony, Philips. Prețuri fixe, garanție.';
---
<Base title={title} description={description}>
  <section class="hero-img"><div class="wrap"><span class="badge">Despre noi</span><h1>Despre Reparatii TV București</h1><p class="lead">Echipă cu peste 10 ani experiență în service televizoare, cu deplasare la domiciliul clientului în București și Ilfov.</p></div></section>
  <section class="sec"><div class="wrap">
    <p>Suntem o echipă de tehnicieni certificați specializați în reparații televizoare de toate tipurile — LED, OLED, QLED și Smart TV. Ne deplasăm gratuit la domiciliul dumneavoastră, diagnosticăm gratuit defecțiunea și vă oferim un deviz clar înainte de orice intervenție.</p>
    <p>Reparăm orice marcă: Samsung, LG, Sony, Philips, Panasonic, Horizon și altele. Folosim piese originale sau compatibile de calitate și oferim garanție de 6–12 luni la fiecare intervenție.</p>
    <h2>Ce ne recomandă</h2>
    <ul class="checks">
      <li>Diagnosticare și deplasare gratuită în București și Ilfov</li>
      <li>Plătiți doar dacă televizorul funcționează</li>
      <li>Intervenție rapidă, de regulă în aceeași zi</li>
      <li>Tehnicieni certificați, peste 10 ani experiență</li>
      <li>Garanție 6–12 luni la piese și manoperă</li>
    </ul>
    <Cta />
  </div></section>
</Base>
