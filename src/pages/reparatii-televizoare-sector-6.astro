---
import Base from '../layouts/Base.astro';
import Cta from '../components/Cta.astro';
import { u } from '../data/site';
const title = 'Reparatii televizoare sector 6 | Reparatii TV LED, QLED, OLED Bucuresti';
const description = 'Reparatii televizoare sector 6 cu deplasare la domiciliu. Reparăm TV-ul la fața locului sau îl preluăm în service. Diagnosticare gratuită, garanție.';
const sectoare = ['Sector 1','Sector 2','Sector 3','Sector 4','Sector 5','Sector 6'];
---
<Base title={title} description={description}>
  <section class="hero-img"><div class="wrap"><span class="badge">Sector 6 · La domiciliu</span><h1>Reparații Televizoare Sector 6 București</h1><p class="lead">Ne deplasăm la domiciliul dumneavoastră în Sector 6 și reparăm televizorul la fața locului sau îl preluăm în service. Diagnosticare gratuită.</p></div></section>
  <section class="sec"><div class="wrap">
    <p>Acoperim întreg Sectorul 6 — Militari, Drumul Taberei, Crângași, Giulești și zonele învecinate — cu deplasare gratuită. Reparăm televizoare LED, OLED și QLED de orice marcă, cu garanție 6–12 luni.</p>
    <h2>Reparăm în toate sectoarele</h2>
    <div class="grid g3">{sectoare.map(s => <div class="card-soft"><strong>{s}</strong><span>Reparații TV la domiciliu cu deplasare gratuită.</span></div>)}</div>
    <h2>Servicii în Sector 6</h2>
    <ul class="checks"><li>TV nu pornește — sursă, placă principală, rescriere eMMC</li><li>Backlight LED și panou LED/OLED/QLED</li><li>Probleme de sunet și software Smart TV</li><li>Curățare internă și înlocuire condensatori devalorizați</li></ul>
    <p>Vedeți și <a href={u('preturi-reparatii-tv/')}>prețurile orientative</a> sau aflați <a href={u('cum-decurge-procesul-de-reparatie/')}>cum decurge procesul</a>.</p>
    <Cta titlu="Reparăm TV-ul în Sector 6 azi!" />
  </div></section>
</Base>
