---
import Base from '../layouts/Base.astro';
import Cta from '../components/Cta.astro';
import { u, STRAZI_PRINCIPALE, SITE } from '../data/site';
import { LOCATII } from '../data/locatii';
const title = 'Reparatii televizoare sector 6 | Reparatii TV LED, QLED, OLED Bucuresti';
const description = 'Reparatii televizoare sector 6 cu deplasare la domiciliu. Reparăm TV-ul la fața locului sau îl preluăm în service. Diagnosticare gratuită, garanție 6–12 luni.';
const norm = (x) => x.toLowerCase().replace(/[ăâ]/g,'a').replace(/î/g,'i').replace(/[șş]/g,'s').replace(/[țţ]/g,'t').replace(/[^a-z0-9]+/g,' ').trim();
const cleanNm = (nm) => nm.replace(/^Reparații TV (pe )?/, '').replace(/^Reparatii TV (pe )?/, '').replace(/\s*[–-]\s*Sector.*$/, '').replace(/\s*\(S\d\)\s*$/i, '').trim();
const fromLoc = LOCATII.filter(([sl, nm]) => /(sector\D{0,3}6\b)|(\(s6\))/i.test(nm)).map(([sl, nm]) => ({ sl, nm: cleanNm(nm) }));
const curated = (STRAZI_PRINCIPALE['6'] || []).map(name => { const k = norm(name); const hit = LOCATII.find(([sl, nm]) => { const kk = norm(cleanNm(nm)); return kk === k || kk.includes(k) || k.includes(kk); }); return { sl: hit ? hit[0] : null, nm: name }; });
let strazi = []; const seen = new Set();
[...curated, ...fromLoc].forEach(x => { const k = norm(x.nm); if (k && !seen.has(k)) { seen.add(k); strazi.push(x); } });
strazi.sort((a, b) => a.nm.localeCompare(b.nm, 'ro'));
const canonical = new URL(Astro.url.pathname, SITE.domeniu).href;
const schemaExtra = { '@context': 'https://schema.org', '@graph': [
  { '@type': 'Service', serviceType: 'Reparații televizoare la domiciliu', name: 'Reparații TV Sector 6 București', url: canonical, description, areaServed: { '@type': 'AdministrativeArea', name: 'Sector 6, București' }, provider: { '@id': 'https://www.reparatiitvbucuresti.ro/#business' }, offers: { '@type': 'Offer', priceCurrency: 'RON', url: SITE.domeniu + '/preturi-reparatii-tv/' } },
  { '@type': 'BreadcrumbList', itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Acasă', item: SITE.domeniu + '/' },
    { '@type': 'ListItem', position: 2, name: 'Sectoare', item: SITE.domeniu + '/sectoare/' },
    { '@type': 'ListItem', position: 3, name: 'Sector 6', item: canonical },
  ] },
] };
---
<Base title={title} description={description} schemaExtra={schemaExtra}>
  <section class="hero-img"><div class="wrap">
    <span class="badge">Sector 6 · La domiciliu</span>
    <h1>Reparații Televizoare Sector 6 București</h1>
    <p class="lead">Ne deplasăm gratuit în Sector 6 și reparăm televizorul la fața locului sau îl preluăm în service. Diagnosticare gratuită, garanție 6–12 luni.</p>
  </div></section>
  <section class="sec"><div class="wrap">
    <img src="https://www.reparatiielectronice.ro/img/tv.jpg" alt="Reparatii TV Sector 6" style="width:100%;max-height:300px;object-fit:cover;border-radius:14px;margin:0 0 18px;box-shadow:0 2px 14px rgba(20,54,93,.12)" loading="lazy" />
    <p>Acoperim întreg Sectorul 6 — Militari, Drumul Taberei, Crângași, Giulești și zonele învecinate — cu deplasare gratuită. Reparăm televizoare LED, OLED și QLED de orice marcă, cu garanție 6–12 luni.</p>
    <h2>Ce reparăm</h2>
    <ul class="checks">
      <li>TV nu pornește — sursă, placă principală, rescriere eMMC cu programator special</li>
      <li>Backlight LED și panou LED / OLED / QLED</li>
      <li>Linii sau pete pe ecran — placă T-CON</li>
      <li>Probleme de sunet și software Smart TV</li>
      <li>Curățare internă și înlocuire condensatori devalorizați</li>
    </ul>
    {strazi.length > 0 && (
      <div>
        <h2>Bulevarde și străzi principale în Sector 6</h2>
        <p>Ne deplasăm gratuit pe toate străzile din Sector 6, inclusiv:</p>
        <div class="grid g3" style="gap:4px 18px">
          {strazi.map(s => s.sl
            ? <a href={u(s.sl + '/')} style="font-size:14px;padding:3px 0;display:block">{s.nm}</a>
            : <span style="font-size:14px;padding:3px 0;display:block;color:var(--ink)">{s.nm}</span>)}
        </div>
      </div>
    )}
    <p style="margin-top:18px">Vedeți <a href={u('preturi-reparatii-tv/')}>prețurile orientative</a> sau aflați <a href={u('cum-decurge-procesul-de-reparatie/')}>cum decurge procesul</a>.</p>
    <Cta titlu="Reparăm TV-ul în Sector 6 azi!" />
  </div></section>
</Base>
